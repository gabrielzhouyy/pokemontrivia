# Copy this file to .env.local and fill in real values.
# .env.local is gitignored (see app/.gitignore).

# Supabase or Neon Postgres connection string.
# For Supabase: use the "Transaction pooler" URI from
#   Project Settings → Database → Connection string → URI mode.
DATABASE_URL=postgresql://user:password@host:6543/postgres

# 32+ random chars used to HMAC-sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-real-random-32-byte-hex-string
